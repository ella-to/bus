# Copy to .env and tweak as needed. Both compose files read these values.

# --- Image versions -----------------------------------------------------------
# Pin to a digest in production for reproducible deploys.
NATS_IMAGE=nats:2.10-alpine
NATS_BOX_IMAGE=natsio/nats-box:latest

# --- Single-node (docker-compose.yml) ----------------------------------------
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222
# Where JetStream persists its data on the host.
NATS_DATA_DIR=./data

# --- 3-node cluster (docker-compose.cluster.yml) -----------------------------
NATS_NODE1_CLIENT_PORT=4222
NATS_NODE1_MONITOR_PORT=8222
NATS_NODE2_CLIENT_PORT=4223
NATS_NODE2_MONITOR_PORT=8223
NATS_NODE3_CLIENT_PORT=4224
NATS_NODE3_MONITOR_PORT=8224
